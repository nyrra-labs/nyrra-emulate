{
  "name": "@nyrra/emulate",
  "version": "0.4.2",
  "description": "Local drop-in replacement services for CI and no-network sandboxes",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./cli": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "homepage": "https://github.com/nyrra-labs/nyrra-emulate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyrra-labs/nyrra-emulate.git",
    "directory": "packages/emulate"
  },
  "bugs": {
    "url": "https://github.com/nyrra-labs/nyrra-emulate/issues"
  },
  "keywords": [
    "emulator",
    "mock",
    "api",
    "vercel",
    "github",
    "google",
    "oauth",
    "testing",
    "ci",
    "local-development"
  ],
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "bin": {
    "emulate": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@hono/node-server": "^1",
    "commander": "^14",
    "picocolors": "^1.1.1",
    "yaml": "^2"
  },
  "devDependencies": {
    "@emulators/apple": "workspace:*",
    "@emulators/aws": "workspace:*",
    "@emulators/clerk": "workspace:*",
    "@emulators/core": "workspace:*",
    "@emulators/foundry": "workspace:*",
    "@emulators/github": "workspace:*",
    "@emulators/google": "workspace:*",
    "@emulators/microsoft": "workspace:*",
    "@emulators/mongoatlas": "workspace:*",
    "@emulators/okta": "workspace:*",
    "@emulators/resend": "workspace:*",
    "@emulators/slack": "workspace:*",
    "@emulators/stripe": "workspace:*",
    "@emulators/vercel": "workspace:*",
    "tsup": "^8",
    "typescript": "^5.7"
  }
}
